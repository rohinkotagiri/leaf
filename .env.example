# PrivateMailAI — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=PrivateMailAI
APP_VERSION=0.1.0
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────
# Default uses SQLite in data/emails.db (relative to project root)
# DATABASE_URL=sqlite+aiosqlite:///data/emails.db

# ── Ollama ───────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=mistral:7b
OLLAMA_FAST_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120
OLLAMA_FAST_TIMEOUT=30
OLLAMA_DEEP_TIMEOUT=120

# ── ChromaDB ─────────────────────────────────────────────────────────────
# CHROMA_PERSIST_DIR=data/chroma

# ── IMAP ─────────────────────────────────────────────────────────────────
IMAP_TIMEOUT=30
IMAP_BATCH_SIZE=50

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# CORS_ORIGINS=["http://localhost:5173"]

# ── Security ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
# ENCRYPTION_KEY=  # Generate with: python -c "from secrets import token_hex; print(token_hex(32))"

# ── Sync ─────────────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=15
MAX_EMAILS_PER_SYNC=200

# ── AI Processing ────────────────────────────────────────────────────────
AI_BATCH_SIZE=10
AI_MAX_RETRIES=3
PROMPT_VERSION=v1.0.0
